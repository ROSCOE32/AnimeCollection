@page
@model AnimeCollection.Pages.Personnages.IndexModel

@{
    ViewData["Title"] = "Personnages";
}

<h1>Personnages</h1>

<a asp-page="Create">Ajouter un personnage</a>

<form method="get">
    <input asp-for="Search" placeholder="Rechercher un personnage ou un animé" />
    <button type="submit">Rechercher</button>
</form>

<table>
    <tr>
        <th>Nom</th>
        <th>Animé</th>
        <th>Statut</th>
        <th>Actions</th>
    </tr>

    @foreach (var personnage in Model.Personnages)
    {
        <tr>
            <td>@personnage.Name</td>
            <td>@personnage.AnimeTitle</td>
            <td>@personnage.Status</td>
            <td>
                <a asp-page="Details" asp-route-id="@personnage.Id">Détails</a>
                |
                <a asp-page="Edit" asp-route-id="@personnage.Id">Modifier</a>
                |
                <a asp-page="Delete" asp-route-id="@personnage.Id">Supprimer</a>
            </td>
        </tr>
    }
</table>